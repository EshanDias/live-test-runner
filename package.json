{
  "name": "live-test-runner",
  "private": true,
  "version": "1.2.0",
  "publisher": "EshLabs",
  "engines": {
    "vscode": "^1.74.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EshanDias/live-test-runner"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "rebuild": "rimraf --glob \"packages/*/{dist,build,out,tsconfig.tsbuildinfo}\" && pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "start": "pnpm --filter live-test-runner run watch"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.0.0"
  }
}
