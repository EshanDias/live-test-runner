{
  "name": "live-test-runner",
  "displayName": "Live Test Runner",
  "description": "Live testing on save for Jest and other frameworks",
  "version": "1.0.4",
  "icon": "resources/images/live-test-runner.png",
  "publisher": "EshLabs",
  "engines": {
    "vscode": "^1.74.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eshandias/live-test-runner",
    "directory": "packages/vscode-extension"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:liveTestRunner.explorer",
    "onView:liveTestRunner.results"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "liveTestRunnerContainer",
          "title": "Live Test Runner",
          "icon": "resources/icons/live_test_runner_vscode_logo.svg"
        }
      ],
      "panel": [
        {
          "id": "liveTestRunnerPanel",
          "title": "Live Test Results",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "liveTestRunnerContainer": [
        {
          "type": "webview",
          "id": "liveTestRunner.explorer",
          "name": "Test Explorer"
        }
      ],
      "liveTestRunnerPanel": [
        {
          "type": "webview",
          "id": "liveTestRunner.results",
          "name": "Live Test Results"
        }
      ]
    },
    "commands": [
      {
        "command": "liveTestRunner.startTesting",
        "title": "Start Testing",
        "category": "Live Test Runner"
      },
      {
        "command": "liveTestRunner.stopTesting",
        "title": "Stop Testing",
        "category": "Live Test Runner"
      },
      {
        "command": "liveTestRunner.selectProjectRoot",
        "title": "Select Project Root",
        "category": "Live Test Runner"
      },
      {
        "command": "liveTestRunner.showOutput",
        "title": "Show Raw Output",
        "category": "Live Test Runner"
      },
      {
        "command": "liveTestRunner.rerunFromEditor",
        "title": "Live Test Runner: Rerun Test at Line"
      },
      {
        "command": "liveTestRunner.debugFromEditor",
        "title": "Live Test Runner: Debug Test at Line"
      },
      {
        "command": "liveTestRunner.focusResult",
        "title": "Live Test Runner: Focus Test in Results Panel"
      }
    ],
    "configuration": {
      "title": "Live Test Runner",
      "properties": {
        "liveTestRunner.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Project root directory for testing"
        },
        "liveTestRunner.jestCommand": {
          "type": "string",
          "default": "",
          "description": "Override the Jest command (e.g. 'node_modules/.bin/jest'). Leave empty to auto-detect from package.json scripts and node_modules. Only used when runMode is 'extension'."
        },
        "liveTestRunner.runMode": {
          "type": "string",
          "enum": [
            "auto",
            "npm"
          ],
          "enumDescriptions": [
            "Extension manages Jest directly — full structured output, per-test durations, console capture.",
            "Use the project's 'npm test' script — respects your package.json test setup but provides limited structured output."
          ],
          "default": "auto",
          "description": "How tests are invoked. 'auto' (recommended): extension calls Jest directly with structured output. 'npm': delegates to 'npm test -- --json' from your package.json scripts."
        },
        "liveTestRunner.onSaveDebounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay in milliseconds before running tests on save"
        },
        "liveTestRunner.showOutputOnFailure": {
          "type": "boolean",
          "default": true,
          "description": "Show raw output channel when tests fail"
        },
        "liveTestRunner.testFilePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.test.*",
            "**/*.spec.*"
          ],
          "description": "Glob patterns for test files"
        },
        "liveTestRunner.durationThresholds": {
          "type": "object",
          "description": "Duration thresholds (ms) for colour-coding test times. Green < amber ≤ yellow < red.",
          "default": {},
          "properties": {
            "testAmberMs": {
              "type": "number",
              "default": 100,
              "description": "Individual test: amber threshold in ms (default 100)"
            },
            "testRedMs": {
              "type": "number",
              "default": 500,
              "description": "Individual test: red threshold in ms (default 500)"
            },
            "suiteAmberMs": {
              "type": "number",
              "default": 500,
              "description": "Suite: amber threshold in ms (default 500)"
            },
            "suiteRedMs": {
              "type": "number",
              "default": 2000,
              "description": "Suite: red threshold in ms (default 2000)"
            },
            "fileAmberMs": {
              "type": "number",
              "default": 1000,
              "description": "File: amber threshold in ms (default 1000)"
            },
            "fileRedMs": {
              "type": "number",
              "default": 5000,
              "description": "File: red threshold in ms (default 5000)"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc --build",
    "build": "pnpm run compile",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@live-test-runner/core": "workspace:*",
    "@live-test-runner/runner": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4",
    "eslint": "^8.28.0"
  }
}
