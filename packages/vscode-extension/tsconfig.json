{
  "compilerOptions": {
    "module": "node16",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "jest"],
    "outDir": "out",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "composite": true
  },
  "references": [{ "path": "../core" }, { "path": "../runner" }],
  "exclude": ["node_modules", ".vscode-test", "out"]
}
